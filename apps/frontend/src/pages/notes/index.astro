---
import { env } from "cloudflare:workers";
import { createBackendClient } from "../../api";
import Base from "../../layouts/Base.astro";
import { parseListResponse } from "../../notes-helpers";

const apiBase = env.PUBLIC_API_URL ?? "http://localhost:8787";
const api = createBackendClient(apiBase);

const url = new URL(Astro.request.url);
const cursor = url.searchParams.get("cursor") ?? undefined;
const limit = parseInt(url.searchParams.get("limit") ?? "20", 10);

const res = await api.notes.$get({
	query: { ...(cursor ? { cursor } : {}), limit: String(limit) },
});
const raw = await res.json();
const { items, nextCursor, isEmpty } = parseListResponse(
	raw as Parameters<typeof parseListResponse>[0],
);
---

<Base title="Notes">
	<main>
		<h1>Notes</h1>
		<a href="/notes/new">New note</a>
		{isEmpty ? (
			<p>No notes yet. <a href="/notes/new">Create your first note</a>.</p>
		) : (
			<ul>
				{items.map((note) => (
					<li>
						<a href={`/notes/${note.id}`}>{note.title}</a>
					</li>
				))}
			</ul>
		)}
		{nextCursor && (
			<a href={`/notes?cursor=${nextCursor}&limit=${limit}`}>Load more</a>
		)}
	</main>
</Base>
