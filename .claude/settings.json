{
	"permissions": {
		"allow": ["Bash(gh:*)", "Bash(git add:*)", "Bash(git commit:*)", "Bash(git push:*)"],
		"deny": ["Bash(*--no-verify*)", "Bash(*git push*--force*)"]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "cd /Users/pierre-mikel/Github/template-BPE && bun run lint"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cd /Users/pierre-mikel/Github/template-BPE && turbo typecheck && turbo test"
					}
				]
			}
		]
	}
}
