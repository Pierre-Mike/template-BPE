{
	"permissions": {
		"allow": ["Bash(gh:*)", "Bash(git add:*)", "Bash(git commit:*)", "Bash(git push:*)"],
		"deny": ["Bash(*--no-verify*)", "Bash(*git push*--force*)"]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run preToolUse"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run postToolUse"
					}
				]
			}
		]
	}
}
