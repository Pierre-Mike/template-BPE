{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"permissions": {
		"allow": [
			"Bash(gh:*)",
			"Bash(git add:*)",
			"Bash(git commit:*)",
			"Bash(git push:*)"
		],
		"deny": [
			"Bash(*--no-verify*)",
			"Bash(*git push*--force*)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "cd /Users/pierre-mikel/Github/template-BPE && bun run lint"
					}
				]
			}
		]
	}
}