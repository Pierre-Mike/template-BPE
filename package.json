{
	"name": "template-bpe",
	"private": true,
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"lint": "biome check --write .",
		"lint:file": "biome check --write",
		"lint:ci": "biome ci .",
		"colocated-tests": "bash scripts/colocated-tests.sh",
		"secret-scan": "gitleaks detect --no-banner",
		"check": "bunx turbo check",
		"prepare": "bunx lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/bun": "latest",
		"lefthook": "^2.1.4",
		"turbo": "^2.7.0",
		"typescript": "^5",
		"zod": "^4.3.6"
	}
}
