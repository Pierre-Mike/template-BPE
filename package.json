{
	"name": "template-bpe",
	"private": true,
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"lint": "biome check --write .",
		"lint:ci": "biome ci .",
		"check": "turbo typecheck test && biome ci .",
		"prepare": "bunx lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/bun": "latest",
		"lefthook": "^2.1.4",
		"turbo": "^2.7.0",
		"typescript": "^5"
	}
}
