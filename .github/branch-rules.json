{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"_comment": "Branch protection rules applied via setup.sh. Requires GitHub Pro (private) or public repo.",
	"branch": "main",
	"protection": {
		"required_pull_request_reviews": null,
		"required_status_checks": {
			"strict": true,
			"contexts": [
				"Type Check",
				"Biome CI",
				"Test",
				"Enforce Co-located Tests",
				"Secret Scan",
				"Build",
				"AI Review",
				"Protected File Check"
			]
		},
		"enforce_admins": false,
		"restrictions": null,
		"allow_force_pushes": true,
		"allow_deletions": false
	}
}
